{
  "manifest_version": 3,
  "name": "PhishVoider",
  "version": "1.0",
  "description": "AI-powered Anti-Phishing Browser Extension",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-default.png",
      "48": "icon-default.png",
      "128": "icon-default.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
