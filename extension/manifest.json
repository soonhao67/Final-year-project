{
  "manifest_version": 3,

  "name": "PhishVoider",

  "version": "2.0.0",

  "description":
    "AI-powered phishing detection browser extension using machine learning.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["warning.html", "warning.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {

    "default_title": "PhishVoider",

    "default_popup": "popup.html",

    "default_icon": {
      "16": "icon-default.png",
      "48": "icon-default.png",
      "128": "icon-default.png"
    }
  },

  "icons": {
    "16": "icon-default.png",
    "48": "icon-default.png",
    "128": "icon-default.png"
  }

}